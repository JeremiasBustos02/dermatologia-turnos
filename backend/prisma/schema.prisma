generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int             @id @default(autoincrement())
  dni                 String          @unique
  firstName           String
  lastName            String
  email               String?         @unique
  password            String
  role                UserRole
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @default(now()) @updatedAt
  deletedAt           DateTime?
  hashedRefreshToken  String?
  coverageId          Int?
  appointments        Appointment[]   @relation("PatientAppointments")
  medicalRecords      MedicalRecord[] @relation("PatientMedicalRecords")
  professionalProfile Professional?
  coverage            Coverage?       @relation(fields: [coverageId], references: [id])

  @@index([coverageId])
  @@index([deletedAt])
}

model Professional {
  id             Int             @id @default(autoincrement())
  firstName      String
  lastName       String
  licenseNumber  String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
  deletedAt      DateTime?
  userId         Int?            @unique
  appointments   Appointment[]   @relation("ProfessionalAppointments")
  medicalRecords MedicalRecord[] @relation("ProfessionalMedicalRecords")
  user           User?           @relation(fields: [userId], references: [id])
  schedules      Schedule[]
  coverages      Coverage[]      @relation("CoverageToProfessional")
  specialties    Specialty[]     @relation("ProfessionalToSpecialty")

  @@index([deletedAt])
}

model MedicalRecord {
  id             Int          @id @default(autoincrement())
  patientId      Int
  professionalId Int
  appointmentId  Int?         @unique
  reason         String?
  evolution      String
  prescription   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  patient        User         @relation("PatientMedicalRecords", fields: [patientId], references: [id])
  professional   Professional @relation("ProfessionalMedicalRecords", fields: [professionalId], references: [id])

  @@index([patientId])
  @@index([patientId, createdAt])
  @@index([professionalId])
  @@index([professionalId, createdAt])
}

model Specialty {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  description   String?
  deletedAt     DateTime?
  professionals Professional[] @relation("ProfessionalToSpecialty")
}

model Coverage {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  deletedAt     DateTime?
  description   String?
  appointments  Appointment[]
  users         User[]
  professionals Professional[] @relation("CoverageToProfessional")
}

model Schedule {
  id                  Int          @id @default(autoincrement())
  professionalId      Int
  startTime           String
  endTime             String
  appointmentDuration Int
  dayOfWeek           DayOfWeek
  professional        Professional @relation(fields: [professionalId], references: [id])

  @@index([professionalId])
  @@index([professionalId, dayOfWeek])
}

model Appointment {
  id             Int               @id @default(autoincrement())
  patientId      Int
  professionalId Int
  coverageId     Int
  dateTime       DateTime
  status         AppointmentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime          @default(now())
  coverage       Coverage          @relation(fields: [coverageId], references: [id])
  patient        User              @relation("PatientAppointments", fields: [patientId], references: [id])
  professional   Professional      @relation("ProfessionalAppointments", fields: [professionalId], references: [id])
  medicalRecord  MedicalRecord?

  @@index([professionalId, dateTime])
  @@index([patientId, dateTime])
  @@index([patientId])
  @@index([coverageId])
  @@index([dateTime])
}

enum UserRole {
  PATIENT
  RECEPTIONIST
  ADMIN
  PROFESSIONAL
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
